    {
      "name": "Autenticacion",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body && body.accessToken) {",
                  "  pm.collectionVariables.set('token', body.accessToken);",
                  "}",
                  "if (body && body.empresaId !== undefined && body.empresaId !== null) {",
                  "  pm.collectionVariables.set('empresaId', String(body.empresaId));",
                  "}",
                  "if (body && body.usuarioId !== undefined && body.usuarioId !== null) {",
                  "  pm.collectionVariables.set('userId', String(body.usuarioId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
